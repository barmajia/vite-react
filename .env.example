# ═══════════════════════════════════════════════════════════
# ⚠️ SECURITY WARNING
# ═══════════════════════════════════════════════════════════
# 
# This file is an EXAMPLE ONLY. DO NOT commit real credentials.
# 
# 1. Copy this file to .env (DO NOT commit .env)
# 2. Replace placeholder values with your actual credentials
# 3. NEVER commit .env to version control
# 4. Rotate credentials if accidentally committed
#
# For production: Use environment variables from your hosting provider
# (Vercel, AWS, etc.) instead of .env files
# ═══════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════
# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
# ═══════════════════════════════════════════════════════════

# Supabase Project URL (public - safe to expose)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Key (public - safe to expose)
# This key is meant to be used in browser/mobile apps
# Row Level Security (RLS) protects your data
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️ NEVER put your service_role key in .env!
# The service_role key bypasses RLS and should ONLY be used
# in server-side code (Edge Functions, backend APIs)
# VITE_SUPABASE_SERVICE_ROLE_KEY=NEVER_EXPOSE_THIS

# ═══════════════════════════════════════════════════════════
# Application Configuration
# ═══════════════════════════════════════════════════════════

# Local development URL
VITE_APP_URL=http://localhost:5173

# Production URL (update when deploying)
# VITE_APP_URL=https://your-domain.com

# ═══════════════════════════════════════════════════════════
# Vercel Analytics (Optional)
# Get this from: https://vercel.com/analytics
# ═══════════════════════════════════════════════════════════

VITE_VERCEL_ANALYTICS_ID=

# ═══════════════════════════════════════════════════════════
# Stripe Payment Integration (Optional)
# Get these from: https://dashboard.stripe.com/apikeys
# ═══════════════════════════════════════════════════════════

# Stripe Publishable Key (public - safe to expose)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ⚠️ NEVER put your Stripe Secret Key in .env!
# Use Supabase Edge Functions for server-side Stripe operations
# STRIPE_SECRET_KEY=sk_test_... (ONLY in Edge Function secrets)
# STRIPE_WEBHOOK_SECRET=whsec_... (ONLY in Edge Function secrets)

# ═══════════════════════════════════════════════════════════
# Google OAuth (Optional)
# Get these from: https://console.cloud.google.com/apis/credentials
# ═══════════════════════════════════════════════════════════

# Google Client ID (public - safe to expose)
# Required for "Sign in with Google" feature
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ⚠️ Google OAuth must be enabled in Supabase Dashboard:
# 1. Go to: https://app.supabase.com/project/_/auth/providers
# 2. Enable "Google" provider
# 3. Add your Google Client ID and Secret
# 4. Set Redirect URL to: https://your-project-id.supabase.co/auth/v1/callback
# 5. In Google Cloud Console, add the above redirect URL to authorized redirect URIs

# ═══════════════════════════════════════════════════════════
# Security Notes
# ═══════════════════════════════════════════════════════════
#
# ✓ .env is in .gitignore - won't be committed
# ✓ VITE_ prefix makes variables available to client
# ✓ Supabase anon key is public by design
# ✓ RLS policies protect your database
# ✓ Use Edge Functions for sensitive operations
#
# For more security best practices, see:
# - SECURITY_GUIDE.md
# - docs/SECURITY.md
# ═══════════════════════════════════════════════════════════
